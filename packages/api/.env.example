# Replicate API token for LLM and image generation
# Get yours at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# LLM model for outline enrichment (default: meta/llama-4-maverick)
# REPLICATE_LLM_MODEL=meta/llama-4-maverick

# Image model for reference generation (default: openai/gpt-image-2)
# REPLICATE_IMAGE_MODEL=openai/gpt-image-2
